@page "/lifecycle"
@using Microsoft.AspNetCore.Components
@inject NavigationManager NavigationManager

<PageTitle>Blazor Life Cycle Sample</PageTitle>

<div class="welcome-screen">
    <div class="logo">
        <h1>Blazor Life Cycle Sample</h1>
        <p>Self-Service Kiosk</p>
    </div>

    <h2>What do you want?</h2>

    <div class="order-options">
        <button type="button" class="option-card" @onclick="StartOrder">
            <span class="icon">✨</span>
            <span class="option-title">START</span>
            <span class="option-description">Click here to open the sample app</span>
        </button>
    </div>

    <div class="mt-4">
        <button type="button" class="btn btn-secondary" @onclick="GoHome">Back to Profile</button>
    </div>
</div>

@code {
    private void StartOrder() => NavigationManager.NavigateTo("/lifecycle/menu");
    private void GoHome() => NavigationManager.NavigateTo("/");
}

@page "/summary"
@rendermode InteractiveServer
@inject NavigationManager NavigationManager

<PageTitle>Order Summary</PageTitle>

<div class="summary-page">
    <h1>Your Order Summary</h1>

    <div class="order-list">
        @foreach (var item in MenuItems)
        {
            if (item.Quantity > 0)
            {
                <div class="summary-item">
                    <span>@item.Quantity x @item.Name</span>
                    <span>₱@(item.Subtotal)</span>
                </div>
            }
        }
    </div>

    <div class="total-section">
        <div class="total-row">
            <strong>Total Items</strong>
            <strong>@TotalItems</strong>
        </div>
        <div class="total-row grand-total">
            <strong>Total Amount</strong>
            <strong>₱@TotalAmount.ToString("N2")</strong>
        </div>
    </div>

    <div class="actions">
        <button class="btn btn-secondary" @onclick="GoBack">← Back to Menu</button>
        <button class="btn btn-primary" @onclick="ConfirmOrder">Confirm Order</button>
    </div>
</div>

@code {
    private List<MenuItem> MenuItems = new();

    private int TotalItems => MenuItems.Sum(x => x.Quantity);
    private decimal TotalAmount => MenuItems.Sum(x => x.Subtotal);

    protected override void OnInitialized()
    {
        // For now, use sample data. Later we can share real cart
        MenuItems = new List<MenuItem>
        {
            new MenuItem { Name = "Kayo ba?", Price = 99, Quantity = 2 }
        };
    }

    private void GoBack() => NavigationManager.NavigateTo("/menu");

    private void ConfirmOrder()
    {
        Console.WriteLine($"Order Confirmed! Total: ₱{TotalAmount}");
    }

    public class MenuItem
    {
        public string Name { get; set; } = "";
        public decimal Price { get; set; }
        public int Quantity { get; set; } = 0;
        public decimal Subtotal => Price * Quantity;
    }
}